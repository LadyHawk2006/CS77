# Supabase Configuration (CYBERSWIFTIE2077)
# Use the new revocable keys (2025-2026 format)

# Publicly accessible URL for your Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Publishable/Anon Key (Safe for client-side use, format: sb_publishable_...)
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_placeholder_value

# Secret/Service Role Key (SERVER-SIDE ONLY, format: sb_secret_...)
# This key bypasses RLS and must NEVER be exposed to the client.
SUPABASE_SERVICE_ROLE_KEY=sb_secret_placeholder_value
